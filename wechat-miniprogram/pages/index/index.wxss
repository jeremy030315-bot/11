/* pages/index/index.wxss */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f1f5f9;
}

.logo-area {
  display: flex;
  align-items: center;
}

.logo-icon {
  font-size: 40rpx;
  margin-right: 10rpx;
}

.logo-text {
  font-weight: bold;
  font-size: 34rpx;
}

.role-switch {
  font-size: 24rpx;
  background: #f1f5f9;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  color: #64748b;
}

.main-content {
  flex: 1;
  height: 0;
}

.tab-content {
  padding: 30rpx;
}

.hero-card {
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  border-radius: 30rpx;
  padding: 40rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.hero-text {
  position: relative;
  z-index: 2;
}

.greeting {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.sub-greeting {
  font-size: 28rpx;
  opacity: 0.8;
}

.hero-bg-icon {
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  font-size: 160rpx;
  opacity: 0.1;
  transform: rotate(15deg);
}

.service-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.service-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 50rpx;
  margin-bottom: 20rpx;
}

.orange { background: #fff7ed; }
.blue { background: #eff6ff; }

.service-name {
  font-weight: bold;
  font-size: 30rpx;
  margin-bottom: 10rpx;
}

.service-price {
  font-size: 24rpx;
  color: #94a3b8;
}

.safety-banner {
  background: #ecfdf5;
  border: 1rpx solid #d1fae5;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: flex-start;
}

.safety-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.safety-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #065f46;
}

.safety-desc {
  font-size: 24rpx;
  color: #047857;
  margin-top: 5rpx;
}

/* Order Cards */
.order-card {
  background: #fff;
  padding: 30rpx;
  border-radius: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.order-info {
  display: flex;
  align-items: center;
}

.order-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.order-title {
  display: block;
  font-weight: bold;
  font-size: 30rpx;
}

.order-pet {
  font-size: 24rpx;
  color: #64748b;
}

.order-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #4f46e5;
}

.order-details {
  margin-bottom: 30rpx;
}

.detail-item {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.accept-btn {
  background: #4f46e5;
  color: #fff;
  font-weight: bold;
  border-radius: 20rpx;
  font-size: 28rpx;
}

/* Tab Bar */
.tab-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0 40rpx;
  background: #fff;
  border-top: 1rpx solid #f1f5f9;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #94a3b8;
}

.tab-item.active {
  color: #4f46e5;
}

.tab-icon {
  font-size: 44rpx;
  margin-bottom: 5rpx;
}

.tab-text {
  font-size: 20rpx;
  font-weight: bold;
}
